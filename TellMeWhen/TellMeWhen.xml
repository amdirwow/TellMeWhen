	<Frame name="TellMeWhen_GroupTemplate" enableMouse="false" toplevel="true" movable="true" parent="UIParent" virtual="true">
		<Size>
			<AbsDimension x="1" y="1"/>
		</Size>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture setAllPoints="true">
					<Color r="0" g="0" b="0" a="0"/>
				</Texture>
			</Layer>
		</Layers>
		<Frames>
			<Button name="$parent_ResizeButton" frameStrata="HIGH">
				<Size>
					<AbsDimension x="10" y="10"/>
				</Size>
				<Anchors>
					<Anchor point="BOTTOMRIGHT" relativeTo="$parent" relativePoint="BOTTOMRIGHT"/>
				</Anchors>
				<Layers>
					<Layer level="BACKGROUND">
						<Texture name="$parentTexture" file="Interface\AddOns\TellMeWhen\Textures\Resize">
							<Size>
								<AbsDimension x="10" y="10"/>
							</Size>
						</Texture>
					</Layer>
				</Layers>
				<Scripts>
					<OnLoad>
						local texture = _G[self:GetName().."Texture"];
						texture:SetVertexColor(0.6, 0.6, 0.6);
					</OnLoad>
					<OnMouseDown>
						TellMeWhen_StartSizing(self, button);
					</OnMouseDown>
					<OnMouseUp>
						TellMeWhen_StopSizing(self, button);
					</OnMouseUp>
					<OnEnter>
						TellMeWhen_GUIButton_OnEnter(self, "RESIZE", "RESIZE_TOOLTIP");
						local texture = getglobal(self:GetName().."Texture");
						texture:SetVertexColor(1, 1, 1);
					</OnEnter>
					<OnLeave>
						GameTooltip:Hide();
						local texture = getglobal(self:GetName().."Texture");
						texture:SetVertexColor(0.6, 0.6, 0.6);
					</OnLeave>
				</Scripts>
			</Button>
		</Frames>
	</Frame>
